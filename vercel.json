{
  "version": 2,
  "builds": [
    { "src": "index.html",           "use": "@vercel/static" },
    { "src": "login.html",           "use": "@vercel/static" },
    { "src": "education.html",       "use": "@vercel/static" },
    { "src": "verify.html",          "use": "@vercel/static" },
    { "src": "dashboard.html",       "use": "@vercel/static" },
    { "src": "dashboard.js",         "use": "@vercel/static" },
    { "src": "session-keep.html",    "use": "@vercel/static" },
    { "src": "onboarding.html",      "use": "@vercel/static" },
    { "src": "alerts-setup.html",    "use": "@vercel/static" },
    { "src": "strategy-setup.html",  "use": "@vercel/static" },
    { "src": "api/quote.js",         "use": "@vercel/node"   },
    { "src": "api/indices.js",       "use": "@vercel/node"   },
    { "src": "api/all.js",           "use": "@vercel/node"   },
    { "src": "api/news.js",          "use": "@vercel/node"   },
    { "src": "api/send-otp.js",      "use": "@vercel/node"   },
    { "src": "api/verify-otp.js",    "use": "@vercel/node"   }
  ],
  "routes": [
    { "src": "/api/quote",           "dest": "/api/quote.js"        },
    { "src": "/api/indices",         "dest": "/api/indices.js"      },
    { "src": "/api/all",             "dest": "/api/all.js"          },
    { "src": "/api/news",            "dest": "/api/news.js"         },
    { "src": "/api/send-otp",        "dest": "/api/send-otp.js"     },
    { "src": "/api/verify-otp",      "dest": "/api/verify-otp.js"   },
    { "src": "/login.html",          "dest": "/login.html"          },
    { "src": "/education.html",      "dest": "/education.html"      },
    { "src": "/verify.html",         "dest": "/verify.html"         },
    { "src": "/dashboard.html",      "dest": "/dashboard.html"      },
    { "src": "/dashboard.js",        "dest": "/dashboard.js"        },
    { "src": "/session-keep.html",   "dest": "/session-keep.html"   },
    { "src": "/onboarding.html",     "dest": "/onboarding.html"     },
    { "src": "/alerts-setup.html",   "dest": "/alerts-setup.html"   },
    { "src": "/strategy-setup.html", "dest": "/strategy-setup.html" },
    { "src": "/(.*)",                "dest": "/index.html"          }
  ]
}
