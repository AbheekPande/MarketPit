* { margin: 0px; padding: 0px; box-sizing: border-box; }

body { background: var(--bg); color: var(--text); font-family: "DM Sans", sans-serif; height: 100vh; display: flex; flex-direction: column; overflow: hidden; transition: background 0.3s, color 0.3s; }

button, a, .stock-item, .feed-card, .card, .pcat-btn, .filter-btn, .bn-item, .notif-btn, .nav-tab { transition: background 0.18s, color 0.18s, border-color 0.18s, box-shadow 0.18s, transform 0.18s, opacity 0.18s !important; }

.stock-item:hover { transform: translateX(3px); background: var(--bg3) !important; }

.filter-btn:hover:not(.active) { background: var(--bg3) !important; color: var(--accent) !important; }

.pcat-btn:hover:not(.active-pcat) { background: var(--bg3) !important; color: var(--accent) !important; }

.bn-item:hover { transform: translateY(-2px); background: rgba(0, 112, 243, 0.1) !important; color: var(--accent) !important; }

.notif-btn:hover { background: var(--accent) !important; color: rgb(255, 255, 255) !important; border-color: var(--accent) !important; }

.feed-scroll, .main-feed { scroll-behavior: smooth; }

