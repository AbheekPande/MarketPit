.nav-tabs { display: flex; gap: 0px; overflow-x: auto; flex-shrink: 1; min-width: 0px; scrollbar-width: none; height: 100%; align-items: stretch; scroll-behavior: smooth; mask-image: linear-gradient(to right, transparent 0px, black 12px, black calc(100% - 32px), transparent 100%); }

