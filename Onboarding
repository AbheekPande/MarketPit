<!DOCTYPE html><html class="light" lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8"><link rel="stylesheet" type="text/css" href="cid:css-c73fb1de-fa8b-444b-8833-f18d127c997f@mhtml.blink" /><link rel="stylesheet" type="text/css" href="cid:css-fef2db4d-dfd9-4b49-8dc0-0d298169ed79@mhtml.blink" />

<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>Tailor Your Terminal | Market Pit</title>
<link href="https://fonts.googleapis.com/" rel="preconnect">
<link crossorigin="" href="https://fonts.gstatic.com/" rel="preconnect">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400&amp;family=Manrope:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">



</head>
<body class="bg-surface text-on-surface font-body selection:bg-primary-fixed selection:text-on-primary-fixed">
<main class="min-h-screen flex flex-col items-center justify-center px-6 py-12">
  <!-- Progress -->
  <div class="w-full max-w-5xl mx-auto mb-10 px-0">
    <div class="flex justify-between items-center mb-3">
      <span class="font-label text-xs tracking-wider uppercase text-on-surface-variant font-semibold">Your Preferences</span>
      <span class="font-label text-xs tracking-wider uppercase text-primary font-bold">Step 1 of 3 &nbsp;·&nbsp; 33% Complete</span>
    </div>
    <div class="w-full bg-surface-container-high h-1.5 rounded-full overflow-hidden">
      <div class="bg-primary h-full rounded-full" style="width:33%"></div>
    </div>
  </div>



  <!-- Header -->
  <header class="w-full max-w-5xl mb-16 text-center lg:text-left">
    <div class="mb-8 inline-block">
      <span class="font-headline italic text-2xl text-primary tracking-tight">Market Pit</span>
    </div>
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
      <div class="max-w-2xl">
        <h1 class="font-headline text-5xl md:text-6xl text-primary font-bold tracking-tight mb-4">
          Tailor Your <span class="serif-italic">Terminal</span>
        </h1>
        <p class="font-body text-lg text-on-surface-variant/80 max-w-xl">
          Select your core interests to personalize your market intelligence feed.
        </p>
      </div>
      <div class="hidden lg:block">
        <button class="text-sm font-label uppercase tracking-widest text-on-surface-variant/60 hover:text-primary transition-colors duration-300">
          Skip for now
        </button>
      </div>
    </div>
  </header>

  <!-- Bento Grid -->
  <section class="w-full max-w-5xl">
    <div class="bento-grid" id="interestGrid">

      <!-- Stocks -->
      <div class="interest-card group relative flex flex-col justify-between p-8 bg-surface-container-low hover:bg-surface-container-lowest rounded-xl transition-all duration-300 cursor-pointer border border-transparent hover:border-outline-variant/30" data-interest="stocks">
        <div class="flex justify-between items-start">
          <span class="material-symbols-outlined card-icon text-on-surface-variant/70 text-3xl">monitoring</span>
          <span class="check-badge hidden bg-primary text-on-primary rounded-full p-1 flex items-center justify-center">
            <span class="material-symbols-outlined" style="font-size:14px;">check</span>
          </span>
        </div>
        <h3 class="card-title font-headline text-xl font-bold text-on-surface mt-8">Stocks</h3>
      </div>

      <!-- Crypto -->
      <div class="interest-card group relative flex flex-col justify-between p-8 bg-surface-container-low hover:bg-surface-container-lowest rounded-xl transition-all duration-300 cursor-pointer border border-transparent hover:border-outline-variant/30" data-interest="crypto">
        <div class="flex justify-between items-start">
          <span class="material-symbols-outlined card-icon text-on-surface-variant/70 text-3xl">currency_bitcoin</span>
          <span class="check-badge hidden bg-primary text-on-primary rounded-full p-1 flex items-center justify-center">
            <span class="material-symbols-outlined" style="font-size:14px;">check</span>
          </span>
        </div>
        <h3 class="card-title font-headline text-xl font-bold text-on-surface mt-8">Crypto</h3>
      </div>

      <!-- Forex -->
      <div class="interest-card group relative flex flex-col justify-between p-8 bg-surface-container-low hover:bg-surface-container-lowest rounded-xl transition-all duration-300 cursor-pointer border border-transparent hover:border-outline-variant/30" data-interest="forex">
        <div class="flex justify-between items-start">
          <span class="material-symbols-outlined card-icon text-on-surface-variant/70 text-3xl">currency_exchange</span>
          <span class="check-badge hidden bg-primary text-on-primary rounded-full p-1 flex items-center justify-center">
            <span class="material-symbols-outlined" style="font-size:14px;">check</span>
          </span>
        </div>
        <h3 class="card-title font-headline text-xl font-bold text-on-surface mt-8">Forex</h3>
      </div>

      <!-- Commodities -->
      <div class="interest-card group relative flex flex-col justify-between p-8 bg-surface-container-low hover:bg-surface-container-lowest rounded-xl transition-all duration-300 cursor-pointer border border-transparent hover:border-outline-variant/30" data-interest="commodities">
        <div class="flex justify-between items-start">
          <span class="material-symbols-outlined card-icon text-on-surface-variant/70 text-3xl">grid_goldenratio</span>
          <span class="check-badge hidden bg-primary text-on-primary rounded-full p-1 flex items-center justify-center">
            <span class="material-symbols-outlined" style="font-size:14px;">check</span>
          </span>
        </div>
        <h3 class="card-title font-headline text-xl font-bold text-on-surface mt-8">Commodities</h3>
      </div>

      <!-- IPOs (wide) -->
      <div class="interest-card group relative flex flex-col justify-between p-8 bg-surface-container-low hover:bg-surface-container-lowest rounded-xl transition-all duration-300 cursor-pointer border border-transparent hover:border-outline-variant/30 lg:col-span-2" data-interest="ipos">
        <div class="flex justify-between items-start">
          <span class="material-symbols-outlined card-icon text-on-surface-variant/70 text-3xl">rocket_launch</span>
          <span class="check-badge hidden bg-primary text-on-primary rounded-full p-1 flex items-center justify-center">
            <span class="material-symbols-outlined" style="font-size:14px;">check</span>
          </span>
        </div>
        <div>
          <h3 class="card-title font-headline text-xl font-bold text-on-surface mt-8">IPOs</h3>
          <p class="text-sm text-on-surface-variant/60 mt-2">Track upcoming market debuts.</p>
        </div>
      </div>

      <!-- Unlisted Shares -->
      <div class="interest-card group relative flex flex-col justify-between p-8 bg-surface-container-low hover:bg-surface-container-lowest rounded-xl transition-all duration-300 cursor-pointer border border-transparent hover:border-outline-variant/30" data-interest="unlisted">
        <div class="flex justify-between items-start">
          <span class="material-symbols-outlined card-icon text-on-surface-variant/70 text-3xl">lock</span>
          <span class="check-badge hidden bg-primary text-on-primary rounded-full p-1 flex items-center justify-center">
            <span class="material-symbols-outlined" style="font-size:14px;">check</span>
          </span>
        </div>
        <h3 class="card-title font-headline text-xl font-bold text-on-surface mt-8">Unlisted Shares</h3>
      </div>

      <!-- Mutual Funds -->
      <div class="interest-card group relative flex flex-col justify-between p-8 bg-surface-container-low hover:bg-surface-container-lowest rounded-xl transition-all duration-300 cursor-pointer border border-transparent hover:border-outline-variant/30" data-interest="mutualfunds">
        <div class="flex justify-between items-start">
          <span class="material-symbols-outlined card-icon text-on-surface-variant/70 text-3xl">account_balance</span>
          <span class="check-badge hidden bg-primary text-on-primary rounded-full p-1 flex items-center justify-center">
            <span class="material-symbols-outlined" style="font-size:14px;">check</span>
          </span>
        </div>
        <h3 class="card-title font-headline text-xl font-bold text-on-surface mt-8">Mutual Funds</h3>
      </div>

      <!-- Macro (full width) -->
      <div class="interest-card group relative flex flex-col justify-between p-8 bg-surface-container-low hover:bg-surface-container-lowest rounded-xl transition-all duration-300 cursor-pointer border border-transparent hover:border-outline-variant/30 lg:col-span-4 lg:flex-row lg:items-center" data-interest="macro">
        <div class="flex items-center gap-6">
          <span class="material-symbols-outlined card-icon text-on-surface-variant/70 text-3xl">public</span>
          <div>
            <h3 class="card-title font-headline text-xl font-bold text-on-surface">Macro</h3>
            <p class="text-sm text-on-surface-variant/60">Global economic indicators and central bank updates.</p>
          </div>
        </div>
        <div class="mt-4 lg:mt-0 flex items-center gap-3">
          <span class="check-badge hidden bg-primary text-on-primary rounded-full p-1 flex items-center justify-center">
            <span class="material-symbols-outlined" style="font-size:14px;">check</span>
          </span>
          <span class="material-symbols-outlined text-on-surface-variant/20">arrow_forward</span>
        </div>
      </div>

    </div>
  </section>

  <!-- Footer -->
  <footer class="w-full max-w-5xl mt-16 flex flex-col sm:flex-row items-center justify-end gap-8 pt-12 border-t border-outline-variant/10">

    <div class="flex flex-col sm:flex-row items-center gap-6 w-full sm:w-auto">
      <button class="w-full sm:w-auto px-8 py-4 text-sm font-label uppercase tracking-widest text-on-surface-variant/60 hover:text-primary transition-colors sm:hidden">
        Skip for now
      </button>
      <button class="w-full sm:w-auto px-12 py-4 bg-gradient-to-br from-primary to-primary-container text-on-primary rounded-lg font-label font-bold uppercase tracking-widest hover:shadow-[0px_10px_30px_rgba(0,50,39,0.2)] transition-all duration-300 transform hover:-translate-y-0.5 active:scale-95">
        Complete Setup
      </button>
    </div>
  </footer>

  <!-- Decorative blobs -->
  <div class="fixed -bottom-24 -right-24 w-96 h-96 bg-primary/5 rounded-full blur-3xl -z-10"></div>
  <div class="fixed -top-24 -left-24 w-64 h-64 bg-secondary-container/20 rounded-full blur-3xl -z-10"></div>
</main>



</body></html>
